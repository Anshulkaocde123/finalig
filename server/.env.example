# ══════════════════════════════════════════════════════════════
#  VNIT Inter-Department Games — SERVER Environment Variables
#  ──────────────────────────────────────────────────────────
#  Copy this file → server/.env   then fill in real values.
#  Or just run:  chmod +x setup-team.sh && ./setup-team.sh
#  DO NOT commit server/.env to version control.
# ══════════════════════════════════════════════════════════════

# ─── App ─────────────────────────────────────────────────────
NODE_ENV=development                # development | production | test
PORT=5000                           # Port the Express server listens on

# ─── Database ────────────────────────────────────────────────
# MongoDB Atlas connection string
# Get this from Anshul or create your own cluster at https://cloud.mongodb.com
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/vnit_sports?retryWrites=true&w=majority

# ─── JWT Authentication ─────────────────────────────────────
# Generate one:  node -e "console.log(require('crypto').randomBytes(48).toString('base64'))"
JWT_SECRET=change_me_to_a_random_64_char_string

# ─── Google OAuth 2.0 (optional for local dev) ──────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:5000/api/auth/register-oauth

# ─── CORS ────────────────────────────────────────────────────
CORS_ORIGIN=http://localhost:5173,http://localhost:5174

# ─── Base URL ────────────────────────────────────────────────
BASE_URL=http://localhost:5000
