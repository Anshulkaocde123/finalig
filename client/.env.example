# ══════════════════════════════════════════════════════════════
#  VNIT Inter-Department Games — CLIENT Environment Variables
#  ──────────────────────────────────────────────────────────
#  Copy this file → client/.env.local   (for local development)
#  Or just run:  chmod +x setup-team.sh && ./setup-team.sh
#  All variables MUST start with VITE_ to be exposed to the browser.
#  DO NOT commit .env.local to version control.
# ══════════════════════════════════════════════════════════════

# ─── API / Backend ───────────────────────────────────────────
VITE_API_URL=http://localhost:5000/api
VITE_SOCKET_URL=http://localhost:5000

# ─── Google OAuth (optional — leave empty to disable) ────────
VITE_GOOGLE_CLIENT_ID=
VITE_ENABLE_GOOGLE_LOGIN=false
